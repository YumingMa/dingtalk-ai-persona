# 复制此文件为 .env 并填写真实值
# cp .env.example .env

# ── 钉钉机器人（在钉钉开放平台创建，Stream 模式）────────────
DINGTALK_APP_KEY=your_app_key_here
DINGTALK_APP_SECRET=your_app_secret_here

# ── HAI Gateway（向管理员申请你的个人 Token）──────────────────
ANTHROPIC_API_KEY=your_hai_gateway_token_here
ANTHROPIC_BASE_URL=https://your-lightchat-server.example
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
